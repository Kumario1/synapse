{
  "name": "@synapse/analyzer-go",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "go",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "setup:binary": "node scripts/setup-go.mjs",
    "test": "node scripts/setup-go.mjs && node --test dist/*.test.js"
  },
  "dependencies": {
    "@synapse/analyzer-core": "0.0.0",
    "@synapse/protocol": "0.0.0"
  }
}
