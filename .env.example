# Synapse — optional LLM analysis layer (OpenRouter)
#
# Copy to .env and fill in your key, then start the daemon with Node's env-file
# support (Node 20.6+):
#
#   node --env-file=.env apps/cli/dist/index.js daemon --member bob --session bob --port 4012
#
# Detection is always deterministic; the LLM only (a) turns conflict summaries
# into a richer, both-sides actionable analysis, and (b) for the narrow
# `contract_divergent` case, synthesizes ONE merged contract both agents adopt
# (the resolver). Leave OPENROUTER_API_KEY unset to run fully offline: you still
# get the deterministic analysis and a deterministic escalate resolution.

# Required to enable the LLM layer. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenRouter model slug used for analysis (any chat model works).
SYNAPSE_LLM_MODEL=anthropic/claude-haiku-4.5

# Optional overrides.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# SYNAPSE_LLM_TIMEOUT_MS=8000
# SYNAPSE_LLM_EXPLAIN=0    # force-disable the analysis layer even with a key
# SYNAPSE_LLM_RESOLVE=0    # force-disable the resolver even with a key
# SYNAPSE_LLM_SUMMARY=0    # force-disable LLM session summaries (Layer II) even with a key
#
# Optional server-side GitHub webhook HMAC secret. When set, POST
# /webhooks/github requires a valid X-Hub-Signature-256 header.
# SYNAPSE_GITHUB_WEBHOOK_SECRET=
#
# Daemon<->server auth has three modes, resolved by the server at startup:
#
#   1. project-key (set SYNAPSE_MASTER_SECRET) — real tenancy. The server mints
#      a per-project key as base64url(HMAC-SHA256(master secret, repoId)); a key
#      authorizes ITS project only. Run `SYNAPSE_MASTER_SECRET=… synapse keygen`
#      (resolving repoId from the git remote, like `up`) to mint a key, then give
#      teammates SYNAPSE_PROJECT_KEY=<key> (or --key). This is the recommended
#      mode when shipping the Dockerized server to a machine.
#   2. shared-token (set SYNAPSE_AUTH_TOKEN, leave MASTER_SECRET unset) — the
#      original all-or-nothing token: any valid token reads/writes any project.
#   3. open (set neither) — no auth; local/dev and the hermetic test suite.
#
# In every mode /health stays open and the GitHub webhook keeps its own HMAC.
# The credential is sent via `?token=` / `Authorization: Bearer`, flag/env only,
# never written to .synapse/config.json.
#
# SYNAPSE_MASTER_SECRET=        # a long random string; enables project-key mode
# SYNAPSE_PROJECT_KEY=          # teammate side: the key `synapse keygen` printed
# SYNAPSE_AUTH_TOKEN=           # legacy shared-token mode (ignored if MASTER_SECRET is set)
#
# Server durable state. Point SYNAPSE_DB_PATH at a file and the server persists
# every repo's live state (sessions, unpushed deltas, recent pushes, edit locks,
# resolutions) to SQLite, resuming it after a restart. Unset = in-memory SQLite
# (ephemeral; identical to the pre-persistence behavior — good for tests).
# SYNAPSE_DB_PATH=.synapse-server/state.db
#
# Python analyzer sidecar (tree-sitter + jedi). The daemon resolves the
# interpreter as: SYNAPSE_PYTHON (explicit) > packages/analyzer-py/.venv >
# python3 on PATH. SYNAPSE_PYTHON_BASE picks the base interpreter used to BUILD
# the venv during `npm run setup:analyzer-py`. Without any Python, .py files
# degrade to file-level detection.
# SYNAPSE_PYTHON=
# SYNAPSE_PYTHON_BASE=python3
#
# Hardening / observability knobs (all optional, defaults shown):
# SYNAPSE_LOG_LEVEL=info             # debug | info | warn | error (JSON lines on stderr)
# SYNAPSE_MAX_PAYLOAD_BYTES=1048576  # server cap per WS message / webhook body
# SYNAPSE_WS_PING_INTERVAL_MS=20000  # server ping; a missed pong terminates the socket
# SYNAPSE_RECONNECT_BASE_MS=500      # daemon reconnect backoff base (full jitter)
# SYNAPSE_RECONNECT_MAX_MS=30000     # daemon reconnect backoff cap
# SYNAPSE_ADAPTIVE_SEVERITY=1        # 0 disables feedback-tuned warn→info demotion
# SYNAPSE_BRANCH_AWARE_SEVERITY=1    # 0 disables cross-branch warn→info demotion
# SYNAPSE_DATABASE_URL=              # postgres://… selects the Postgres state store
#                                    # (SYNAPSE_DB_PATH = SQLite file; neither = in-memory)
# SYNAPSE_REDIS_URL=                 # redis://… enables multi-instance fan-out (pair it
#                                    # with a shared SYNAPSE_DATABASE_URL)
# SYNAPSE_FILE_WATCHER=1             # 0 disables the daemon's worktree file watcher
# SYNAPSE_WATCH_DEBOUNCE_MS=400      # per-file quiet window before a watched change reports
#
# Privacy note: the resolver sends the computing agent's full file plus its
# dependency-graph neighbors to the model so the merge is caller-aware — this
# relaxes the "raw code stays local" default. Point OPENROUTER_BASE_URL at a
# local/self-hosted, OpenAI-compatible endpoint to keep code on your machine.
